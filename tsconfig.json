{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@nemesis-js/common": ["./packages/common/src"],
      "@nemesis-js/common/*": ["./packages/common/src/*"],
      "@nemesis-js/core": ["./packages/core/src"],
      "@nemesis-js/core/*": ["./packages/core/src/*"],
      "@nemesis-js/platform-bun": ["./packages/platform-bun/src"],
      "@nemesis-js/platform-bun/*": ["./packages/platform-bun/src/*"],
      "@nemesis-js/http": ["./packages/http/src"],
      "@nemesis-js/http/*": ["./packages/http/src/*"],
      "@nemesis-js/testing": ["./packages/testing/src"],
      "@nemesis-js/testing/*": ["./packages/testing/src/*"],
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "files": [],
  "references": [
    { "path": "./packages/common" },
    { "path": "./packages/core" },
    { "path": "./packages/platform-bun" },
    { "path": "./packages/http" },
    { "path": "./packages/testing" }
  ]
}
