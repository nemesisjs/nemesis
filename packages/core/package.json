{
  "name": "@nemesis-js/core",
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "version": "0.1.0",
  "description": "NemesisJS core - DI container, module system, and application factory",
  "author": "NemesisJS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nemesisjs/nemesis.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "bun test"
  },
  "dependencies": {
    "@nemesis-js/common": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
